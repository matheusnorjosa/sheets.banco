generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?

  // Google OAuth
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sheetApis    SheetApi[]
}

model SheetApi {
  id            String   @id @default(cuid())
  name          String
  spreadsheetId String
  slug          String?  @unique // custom endpoint e.g. "products"

  // Owner
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Permissions
  allowRead   Boolean @default(true)
  allowCreate Boolean @default(true)
  allowUpdate Boolean @default(true)
  allowDelete Boolean @default(true)

  // Auth (opt-in)
  bearerToken String? @unique
  basicUser   String?
  basicPass   String?

  // Security
  corsOrigins String?
  ipWhitelist String?
  rateLimitRpm Int    @default(60)

  // Cache
  cacheTtlSeconds Int @default(60)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  apiKeys              ApiKey[]
  usageLogs            UsageLog[]
  webhookSubscriptions WebhookSubscription[]
}

model ApiKey {
  id         String   @id @default(cuid())
  key        String   @unique @default(cuid())
  sheetApiId String
  sheetApi   SheetApi @relation(fields: [sheetApiId], references: [id], onDelete: Cascade)
  label      String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model UsageLog {
  id         String   @id @default(cuid())
  sheetApiId String
  sheetApi   SheetApi @relation(fields: [sheetApiId], references: [id], onDelete: Cascade)
  method     String
  path       String
  statusCode Int
  responseMs Int
  ip         String?
  createdAt  DateTime @default(now())

  @@index([sheetApiId, createdAt])
}

model WebhookSubscription {
  id         String   @id @default(cuid())
  sheetApiId String
  sheetApi   SheetApi @relation(fields: [sheetApiId], references: [id], onDelete: Cascade)
  url        String
  secret     String
  events     String[] // "row.created", "row.updated", "row.deleted", "rows.cleared"
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  deliveries WebhookDelivery[]
}

model WebhookDelivery {
  id             String   @id @default(cuid())
  subscriptionId String
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  event          String
  payload        Json
  status         String   @default("pending") // pending, success, failed
  attempts       Int      @default(0)
  responseCode   Int?
  createdAt      DateTime @default(now())

  @@index([subscriptionId, createdAt])
}
