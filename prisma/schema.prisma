generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?

  // Google OAuth
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?

  // 2FA (TOTP)
  totpSecret    String?
  totpEnabled   Boolean  @default(false)
  recoveryCodes String[] // bcrypt hashes

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sheetApis    SheetApi[]
}

model SheetApi {
  id            String   @id @default(cuid())
  name          String
  spreadsheetId String
  slug          String?  @unique

  // Owner
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Permissions
  allowRead   Boolean @default(true)
  allowCreate Boolean @default(true)
  allowUpdate Boolean @default(true)
  allowDelete Boolean @default(true)

  // Auth (opt-in)
  bearerToken         String?   @unique
  bearerTokenPrevious String?
  bearerTokenRotatedAt DateTime?
  basicUser           String?
  basicPass           String?

  // HMAC Request Signing
  hmacSecret     String?
  requireSigning Boolean @default(false)

  // Security
  corsOrigins  String?
  ipWhitelist  String?
  rateLimitRpm Int    @default(60)

  // Cache
  cacheTtlSeconds Int @default(60)

  // Scheduled Sync
  syncEnabled  Boolean @default(false)
  syncCron     String? // cron expression, e.g. "*/15 * * * *"

  // Auto-snapshot
  autoSnapshotOnWrite Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  apiKeys              ApiKey[]
  usageLogs            UsageLog[]
  webhookSubscriptions WebhookSubscription[]
  auditLogs            AuditLog[]
  computedFields       ComputedField[]
  snapshots            Snapshot[]
  additionalSheets     AdditionalSheet[]
}

model ApiKey {
  id         String   @id @default(cuid())
  key        String   @unique @default(cuid())
  sheetApiId String
  sheetApi   SheetApi @relation(fields: [sheetApiId], references: [id], onDelete: Cascade)
  label      String?
  scopes     String[] @default(["sheets:read", "sheets:write", "sheets:delete"])
  active     Boolean  @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
}

model UsageLog {
  id         String   @id @default(cuid())
  sheetApiId String
  sheetApi   SheetApi @relation(fields: [sheetApiId], references: [id], onDelete: Cascade)
  method     String
  path       String
  statusCode Int
  responseMs Int
  ip         String?
  createdAt  DateTime @default(now())

  @@index([sheetApiId, createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String
  action       String   // "api.created", "api.deleted", "settings.updated", etc.
  resourceType String   // "SheetApi", "ApiKey", "User"
  resourceId   String
  sheetApiId   String?
  sheetApi     SheetApi? @relation(fields: [sheetApiId], references: [id], onDelete: SetNull)
  changes      Json?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([resourceType, resourceId])
}

model WebhookSubscription {
  id         String   @id @default(cuid())
  sheetApiId String
  sheetApi   SheetApi @relation(fields: [sheetApiId], references: [id], onDelete: Cascade)
  url        String
  secret     String
  events     String[]
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  deliveries WebhookDelivery[]
}

model WebhookDelivery {
  id             String   @id @default(cuid())
  subscriptionId String
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  event          String
  payload        Json
  status         String   @default("pending")
  attempts       Int      @default(0)
  responseCode   Int?
  createdAt      DateTime @default(now())

  @@index([subscriptionId, createdAt])
}

model ComputedField {
  id         String   @id @default(cuid())
  sheetApiId String
  sheetApi   SheetApi @relation(fields: [sheetApiId], references: [id], onDelete: Cascade)
  name       String   // virtual field name
  expression String   // e.g. "{{firstName}} {{lastName}}" or "{{price}} * {{quantity}}"
  createdAt  DateTime @default(now())

  @@unique([sheetApiId, name])
}

model Snapshot {
  id         String   @id @default(cuid())
  sheetApiId String
  sheetApi   SheetApi @relation(fields: [sheetApiId], references: [id], onDelete: Cascade)
  version    Int
  data       Json     // full sheet data at snapshot time
  headers    String[] // column names at snapshot time
  rowCount   Int
  sheetName  String?
  createdAt  DateTime @default(now())

  @@unique([sheetApiId, version])
  @@index([sheetApiId, createdAt])
}

model AdditionalSheet {
  id            String   @id @default(cuid())
  sheetApiId    String
  sheetApi      SheetApi @relation(fields: [sheetApiId], references: [id], onDelete: Cascade)
  spreadsheetId String
  label         String   // friendly name for this additional spreadsheet
  createdAt     DateTime @default(now())

  @@unique([sheetApiId, spreadsheetId])
}
