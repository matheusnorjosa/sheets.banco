# sheets.banco API — root .env (consumed by packages/api)
# Copy to `.env` and fill in. Validated by `packages/api/src/config/env.ts`
# at startup — invalid/missing values exit the process with a clear message.

# ──────────────────────────────────────────────────────────────────
# Runtime
# ──────────────────────────────────────────────────────────────────

# `development` | `test` | `production`. In `production`, extra checks fire:
# JWT_SECRET must be ≥ 32 chars and ALLOWED_ORIGINS is required.
NODE_ENV=development

# `fatal` | `error` | `warn` | `info` | `debug` | `trace`. `debug`/`trace`
# also turn on Prisma query logs (verbose, dev-only).
LOG_LEVEL=info

PORT=3000
HOST=0.0.0.0

# Maximum request body size in bytes. Default 1 MiB matches Fastify's old
# hardcoded value. Bump (e.g. 26_214_400 for 25 MiB) for large CSV imports.
BODY_LIMIT=1048576

# ──────────────────────────────────────────────────────────────────
# Database (Postgres — Supabase / Neon / local)
# ──────────────────────────────────────────────────────────────────

# Use the session pooler (port 5432) for Prisma; transaction pooler (6543)
# breaks `prisma db push` schema introspection. URL-encode `%`/`/` etc. in
# the password.
DATABASE_URL="postgresql://user:password@host:5432/sheets_banco"

# ──────────────────────────────────────────────────────────────────
# Redis (cache + BullMQ queues — Upstash / local)
# ──────────────────────────────────────────────────────────────────

# Optional — without it, BullMQ queues/workers are disabled (writes/webhooks
# /scheduled-sync go offline) but reads still work.
REDIS_URL="redis://localhost:6379"

# ──────────────────────────────────────────────────────────────────
# Google OAuth (per-user — each User has their own access/refresh token)
# ──────────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/google/callback"
# Production: GOOGLE_REDIRECT_URI="https://your-api.onrender.com/auth/google/callback"

# ──────────────────────────────────────────────────────────────────
# Auth (JWT for dashboard sessions)
# ──────────────────────────────────────────────────────────────────

# Min 16 chars in development; **min 32 chars in production**. Generate with
# `openssl rand -base64 32`.
JWT_SECRET="change-me-min-16-chars-in-dev-min-32-in-prod"

# ──────────────────────────────────────────────────────────────────
# CORS (global, for dashboard/auth routes — sheet routes use per-API CORS)
# ──────────────────────────────────────────────────────────────────

# Where the dashboard lives. Used as default origin when ALLOWED_ORIGINS is
# unset (development only).
FRONTEND_URL=http://localhost:3001
# Production: FRONTEND_URL="https://your-app.vercel.app"

# Comma-separated allowlist of origins. **Required in production** (process
# exits at boot otherwise). In dev, falls back to FRONTEND_URL.
# Example: ALLOWED_ORIGINS=https://sheets-banco-web.vercel.app,https://staging.example.com
ALLOWED_ORIGINS=
