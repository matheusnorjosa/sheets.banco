{
  "name": "sheets.banco",
  "version": "0.1.0",
  "private": true,
  "description": "Turn Google Sheets into REST APIs",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w packages/api",
    "dev:web": "npm run dev -w packages/web",
    "build": "npm run build -w packages/api",
    "build:web": "npm run build -w packages/web",
    "build:sdk": "npm run build -w packages/sdk",
    "lint": "npm run lint -w packages/api",
    "typecheck": "npm run typecheck -w packages/api",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "seed": "npm run seed -w packages/api",
    "prepare": "husky || true"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prisma": "^6.19.3"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "next": {
      "postcss": "^8.5.10"
    }
  },
  "lint-staged": {
    "packages/api/**/*.ts": [
      "npm run lint -w packages/api -- --fix"
    ]
  }
}
